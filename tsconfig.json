{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"outDir": "dist",
		"rootDir": "src",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"verbatimModuleSyntax": true,
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitAny": true,
		"baseUrl": ".",
		"paths": {
			"@assets/*": ["./BetterDiscord/assets/*"],
			"@common/*": ["./BetterDiscord/src/common/*"],
			"@builtins/*": ["./BetterDiscord/src/betterdiscord/builtins/*"],
			"@data/*": ["./BetterDiscord/src/betterdiscord/data/*"],
			"@api/*": ["./BetterDiscord/src/betterdiscord/api/*"],
			"@modules/*": ["./BetterDiscord/src/betterdiscord/modules/*"],
			"@polyfill/*": ["./BetterDiscord/src/betterdiscord/polyfill/*"],
			"@stores/*": ["./BetterDiscord/src/betterdiscord/stores/*"],
			"@structs/*": ["./BetterDiscord/src/betterdiscord/structs/*"],
			"@styles/*": ["./BetterDiscord/src/betterdiscord/styles/*"],
			"@ui/*": ["./BetterDiscord/src/betterdiscord/ui/*"],
			"@utils/*": ["./BetterDiscord/src/betterdiscord/utils/*"],
			"@webpack": ["./BetterDiscord/src/betterdiscord/webpack"]
		},
		"typeRoots": [
			"./node_modules/@types",
			"./BetterDiscord/node_modules/@types",
			"./BetterDiscord/src/betterdiscord/types",
		]
	},
	"include": ["src/**/*", "index.d.ts", "discord-data-stores.d.ts"]
}
